{
  "permissions": {
    "allow": [
      "Bash(terraform fmt *)",
      "Bash(echo \"FMT_EXIT:$?\")",
      "Bash(terraform validate *)",
      "Bash(echo \"VALIDATE_EXIT:$?\")",
      "Bash(tflint --recursive terraform/environments/pilot)",
      "Bash(echo \"TFLINT_EXIT:$?\")",
      "Bash(tfsec terraform/environments/pilot)",
      "Bash(echo \"TFSEC_EXIT:$?\")",
      "Bash(tflint --chdir=terraform/environments/pilot)",
      "Bash(terraform init *)",
      "Bash(tflint --recursive terraform/bootstrap)",
      "Bash(tflint --chdir=terraform/bootstrap)",
      "Bash(checkov --directory terraform/bootstrap --framework terraform --quiet)"
    ]
  }
}
